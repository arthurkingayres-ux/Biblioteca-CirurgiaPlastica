      "domain": "técnica"
    },
    {
      "front": "Umbilicoplastia: sutura umbilical",
      "back": "Pontos profundos absorvíveis + interrompidos Nylon 3-0 e 4-0; NÃO ancorar ao plano fascial",
      "citation": "Neligan, 2023, vol. 2, cap. 27",
      "domain": "técnica"
    },
    {
      "front": "Dose epinefrina superwet (tóxica)",
      "back": "0,07 mg/kg de adrenalina 1:1.000 — limite máximo",
