      "domain": "técnica"
    },
    {
      "front": "Drenos na abdominoplastia",
      "back": "Dois Jackson-Pratt (JP) No. 10 pré-embebidos em Betadine; saída lateral na ferida; retirar quando <= 30 mL/dia",
      "citation": "Neligan, 2023, vol. 2, cap. 27",
      "domain": "técnica"
    },
