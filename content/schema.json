{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "biblioteca-cirurgia-plastica/document-schema",
  "title": "Documento de Estudo — Biblioteca de Cirurgia Plástica",
  "description": "Schema para conteúdo dos documentos .docx gerados por create_docx.js",
  "type": "object",
  "required": ["filename", "title", "version", "date", "history", "references", "updates", "body"],
  "additionalProperties": false,
  "properties": {
    "filename": {
      "type": "string",
      "description": "Nome do arquivo .docx de saída (ex: 12-1-Rinoplastia.docx)"
    },
    "title": {
      "type": "string",
      "description": "Título do documento (ex: 12-1 — Rinoplastia)"
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+$",
      "description": "Versão no formato vX.Y"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Data da versão atual (YYYY-MM-DD)"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 3,
        "maxItems": 3,
        "description": "[versão, data, descrição]"
      }
    },
    "references": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Referências-base (Neligan, Grabb & Smith, etc.)"
    },
    "updates": {
      "type": "object",
      "required": ["label", "entries"],
      "properties": {
        "label": { "type": "string", "description": "Rótulo da seção (ex: Atualizações Incorporadas — v2.0 (2026-03-28))" },
        "entries": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lista de referências de artigos incorporados"
        }
      }
    },
    "body": {
      "type": "array",
      "items": { "$ref": "#/$defs/element" },
      "description": "Sequência de elementos do documento"
    }
  },
  "$defs": {
    "element": {
      "oneOf": [
        { "$ref": "#/$defs/heading" },
        { "$ref": "#/$defs/paragraph" },
        { "$ref": "#/$defs/box" },
        { "$ref": "#/$defs/flashcards" },
        { "$ref": "#/$defs/dataTable" },
        { "$ref": "#/$defs/figure" }
      ]
    },
    "heading": {
      "type": "object",
      "required": ["type", "level", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "heading" },
        "level": { "type": "integer", "minimum": 1, "maximum": 3 },
        "text": { "type": "string" }
      }
    },
    "paragraph": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "paragraph" },
        "text": { "type": "string", "description": "Texto do parágrafo" },
        "citation": { "type": "string", "description": "Citação inline (ex: Neligan, 2023, vol. 2, cap. 16)" }
      }
    },
    "box": {
      "type": "object",
      "required": ["type", "color", "title", "lines"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "box" },
        "color": { "enum": ["blue", "red", "green"] },
        "title": { "type": "string" },
        "lines": {
          "type": "array",
          "items": { "type": "string" }
        },
        "citation": { "type": "string" }
      }
    },
    "flashcards": {
      "type": "object",
      "required": ["type", "rows"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "flashcards" },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 2
          }
        }
      }
    },
    "dataTable": {
      "type": "object",
      "required": ["type", "headers", "rows"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "dataTable" },
        "headers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "figure": {
      "type": "object",
      "required": ["type", "image", "widthCm", "heightCm"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "figure" },
        "image": { "type": "string", "description": "Nome do arquivo de imagem (relativo a assets/images/<tema>/)" },
        "widthCm": { "type": "number" },
        "heightCm": { "type": "number" },
        "caption": { "type": "string" }
      }
    }
  }
}
